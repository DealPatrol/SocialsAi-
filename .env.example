# AI
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Auth (generate: openssl rand -base64 32)
AUTH_SECRET=your_auth_secret_here
NEXTAUTH_URL=http://localhost:3000

# Token encryption (defaults to AUTH_SECRET if unset)
ENCRYPTION_KEY=

# Database (libSQL — local file or Turso URL)
DATABASE_URL=file:./data/socials.db

# X (Twitter) OAuth 2.0 — https://developer.x.com/
# Required scopes: tweet.read tweet.write users.read follows.read follows.write dm.read dm.write offline.access
# Callback URL: http://localhost:3000/api/accounts/x/callback
X_CLIENT_ID=
X_CLIENT_SECRET=
X_CALLBACK_URL=http://localhost:3000/api/accounts/x/callback

# Cron (Vercel Cron / manual trigger)
CRON_SECRET=

# Legacy Twitter vars (optional — app uses X_CLIENT_* above)
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
APP_URL=http://localhost:3000
