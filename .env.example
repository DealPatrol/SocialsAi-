# AI
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Twitter / X OAuth 2.0 — create app at developer.twitter.com
# Required scopes: tweet.read, tweet.write, users.read, offline.access
# Set callback URL to: https://yourdomain.com/api/auth/callback/twitter
TWITTER_CLIENT_ID=your_twitter_client_id
TWITTER_CLIENT_SECRET=your_twitter_client_secret

# Your deployed app URL (no trailing slash)
APP_URL=https://yourdomain.com
# Auth (generate: openssl rand -base64 32)
AUTH_SECRET=your_auth_secret_here
NEXTAUTH_URL=http://localhost:3000

# Token encryption (defaults to AUTH_SECRET if unset)
ENCRYPTION_KEY=

# Database (libSQL — local file or Turso URL)
DATABASE_URL=file:./data/socials.db

# X (Twitter) API — https://developer.x.com/
X_CLIENT_ID=
X_CLIENT_SECRET=
X_CALLBACK_URL=http://localhost:3000/api/accounts/x/callback

# Cron (Vercel Cron / manual trigger)
CRON_SECRET=
